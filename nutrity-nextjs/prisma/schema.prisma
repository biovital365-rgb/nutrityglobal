generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                   String                 @id @default(cuid())
  name                 String
  createdAt            DateTime               @default(now())
  appointments         Appointment[]
  biologicalDiagnoses  BiologicalDiagnosis[]
  courses              Course[]
  enrollments          Enrollment[]
  evaluations          Evaluation[]
  foods                Food[]
  measurements         Measurement[]
  micros               Micronutrient[]
  Post                 Post[]
  pdfReports           PDFReportLog[]
  users                User[]
}

model User {
  id               String        @id @default(uuid())
  firebaseUid      String?       @unique
  email            String        @unique
  name             String?
  role             String        @default("USER")
  plan             String        @default("FREE")
  stripeCustomerId String?       @unique
  subscriptionId   String?       @unique
  organizationId   String?
  phone            String?
  address          String?
  age              String?
  occupation       String?
  maritalStatus    String?
  socialMedia      String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?
  appointments        Appointment[]
  biologicalDiagnoses BiologicalDiagnosis[]
  dailyMenus          DailyMenu[]
  enrollments         Enrollment[]
  evaluations         Evaluation[]
  measurements        Measurement[]
  pdfReports          PDFReportLog[]
  organization        Organization? @relation(fields: [organizationId], references: [id])
}

model Food {
  id                String        @id @default(cuid())
  name              String
  scientificName    String
  image             String
  category          String
  description       String
  metabolicBenefits Json
  nutrients         Json
  recipes           Json
  createdAt         DateTime      @default(now())
  deletedAt         DateTime?
  organizationId    String?
  organization      Organization? @relation(fields: [organizationId], references: [id])
}

model Micronutrient {
  id              String        @id @default(cuid())
  name            String
  symbol          String
  category        String
  function        String
  metabolicImpact String
  sources         Json
  deficiencySigns Json
  dailyDose       String
  image           String?
  createdAt       DateTime      @default(now())
  deletedAt       DateTime?
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])
}

model Measurement {
  id             String        @id @default(cuid())
  userId         String
  organizationId String?
  label          String
  value          String
  date           String
  time           String?
  status         String?
  timestamp      DateTime      @default(now())
  organization   Organization? @relation(fields: [organizationId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
}

model Appointment {
  id             String        @id @default(cuid())
  userId         String
  organizationId String?
  title          String
  date           String
  time           String?
  type           String
  status         String        @default("SCHEDULED")
  createdAt      DateTime      @default(now())
  deletedAt      DateTime?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
}

model Evaluation {
  id             String        @id @default(cuid())
  userId         String
  organizationId String?
  data           Json
  results        Json
  timestamp      DateTime      @default(now())
  organization   Organization? @relation(fields: [organizationId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
}

model Course {
  id             String        @id @default(cuid())
  organizationId String?
  title          String
  description    String
  thumbnail      String
  category       String        @default("Bienestar")
  price          Float         @default(0)
  paypalUrl      String?
  currency       String        @default("USD")
  isPublished    Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  enrollments    Enrollment[]
  lessons        Lesson[]
}

model Lesson {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  videoUrl    String?
  duration    String?
  order       Int
  isFree      Boolean  @default(false)
  createdAt   DateTime @default(now())
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id             String        @id @default(cuid())
  userId         String
  organizationId String?
  courseId       String
  enrolledAt     DateTime      @default(now())
  course         Course        @relation(fields: [courseId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
}

model LessonProgress {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  completed Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
}

model DailyMenu {
  id            String    @id @default(cuid())
  userId        String
  date          String
  weekStart     String?
  phase         String?
  status        String    @default("PENDING")
  menuData      Json
  metabolicGoal String?
  adminNotes    String?
  approvedBy    String?
  approvedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  user          User      @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model Post {
  id             String        @id @default(cuid())
  organizationId String?
  title          String
  slug           String        @unique
  content        String
  excerpt        String?
  thumbnail      String?
  category       String
  tags           Json?
  isPublished    Boolean       @default(false)
  isPremium      Boolean       @default(false)
  author         String        @default("Nutrity Global")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization? @relation(fields: [organizationId], references: [id])
}

model PDFReportLog {
  id             String        @id @default(cuid())
  userId         String
  organizationId String?
  status         String        @default("GENERATED")
  errorMessage   String?
  timestamp      DateTime      @default(now())
  createdAt      DateTime      @default(now())
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization? @relation(fields: [organizationId], references: [id])
}

// ─── TRIAJE HOLÍSTICO NMG ────────────────────────────────────────────────────
// Almacena el síntoma principal del paciente + la decodificación biológica
// que la IA genera durante el Onboarding. Permite audit trail clínico.
model BiologicalDiagnosis {
  id                     String        @id @default(cuid())
  userId                 String
  organizationId         String?
  // Síntoma declarado por el paciente
  mainSymptom            String        // ej: "Acidez estomacal", "Fatiga crónica"
  affectedSystem         String        // ej: "Digestivo", "Inmune", "Hormonal"
  symptomDuration        String?       // ej: "6 meses", "2 años"
  emotionalContext       String?       // ej: "miedo al futuro", "conflicto de territorio"
  // Resultado de la IA (NMG/Biodescodificación)
  nmgConflict            String?       // La raíz emocional identificada
  nmgOrgan               String?       // El órgano o sistema biológico involucrado
  holisticApproach       Json?         // Array de disciplinas: MTC, Ayurveda, PNL, etc.
  aiRawResponse          String?       // El texto íntegro de la IA para auditoría
  // Control
  phase                  String        @default("DIAGNOSIS") // DIAGNOSIS, INTERVENTION, REMISSION
  isActive               Boolean       @default(true)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  organization           Organization? @relation(fields: [organizationId], references: [id])
  user                   User          @relation(fields: [userId], references: [id])
}
